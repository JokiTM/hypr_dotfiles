
font=Sauce Code Pro 10
layer=overlay
anchor=bottom-right
width=320
padding=8
margin=8
border-size=2
default-timeout=5000
border-radius=40

background-color=#1b0d0c
text-color=#C5743B

[urgency=low]
border-color=#916545
background-color=#C37D44
text-color=#BB8550

[urgency=normal]
border-color=#C5743B
background-color=#B87442
text-color=#D7913F
default-timeout=10000
ignore-timeout=1

[urgency=high]
font=Sauce Code Pro 16
border-color=#C5743B
background-color=#916545
text-color=#BB8550
default-timeout=0
ignore-timeout=1
