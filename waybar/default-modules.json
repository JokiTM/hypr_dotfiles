{
    "include": "~/.config/waybar/hw-modules.json",
    "hyprland/workspaces": {
        "show-special": true,
        "all-outputs": false,
        "special-visible-only": true,
        "format": "{icon}", 
        "format-icons": {
            "piracy": "¾░Ā│",
            "obs": "’ĆĮ",
            "thunderbird": "Ņ¼£",
            "music": "¾░Äć",
            "scrap": "¾░½ó",
            "sysmon": "Ņł┤",
            "whatsapp": "¾░¢Ż"
        },
        "on-scroll-down": "hyprctl dispatch workspace +1",
        "on-scroll-up": "hyprctl dispatch workspace -1"
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "timezone": "Europe/Berlin",
        //"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        //"format-alt": "’Ś¼ {:%d/%m/%Y}",
        //"format": "’ÖÅ {:%H:%M}"
        "tooltip-format": "<tt>{calendar}</tt>",
        "format": "¾░źö {:%H:%M}",
        "calendar": {
        //    "mode": "month",
        //    "mode-mon-col": 3,
        //    "weeks-pos": "left",
        //    "on-scroll": 1,
            "format": {
        //        "months": "<span color='#ffead3'><b>{}</b></span>",
        //        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        //        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        //        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
    },
    "pulseaudio": {
        "scroll-step": 2,
        "format": "{icon}  {volume}%",
        "format-muted": "’æ”",
        "format-icons": {
            "default": ["’Ć”", "’Ć¦", "’Ć© "]
        },
        "on-click": "pkill wiremix || foot -T wiremix zsh -c '~/.config/hypr/scripts/dispatch.sh wiremix'",
        "on-click-right": "~/.config/waybar/scripts/toggleAudioDevice.sh"
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "loginctl lock-session",
        "format": "’ĆŻ"
    },
    "custom/power": {
        "tooltip": false,
        "on-click": "loginctl hibernate",
        "on-click-right": "wlogout &",
        "format": "ŌÅ╗"
    },
    "custom/soypower": {
        "tooltip": false,
        "on-click": "~/.config/waybar/scripts/hibernate.sh",
        "on-click-right": "wlogout &",
        "format": "ŌÅ╗"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "’ü«",
            "deactivated": "’ü░"
        }
    },
    "custom/vpn": {
        "format": " {}",
        "exec": "~/.config/waybar/scripts/vpnstat.sh",
        "on-click": "~/.local/bin/vpntoggle.sh",
        "signal": 1,
        "interval": "once"
    },
    "mpris#long": {
        "player": "mpd",
        "format": "<i>{dynamic}</i>",
        "dynamic-order": ["title", "{dynamic-seperator}", "artist"],
        "on-click": "~/.config/waybar/scripts/media.sh",
        "on-click-right": "playerctl play-pause",
        "on-scroll-up": "playerctl -p mpd volume .05+",
        "on-scroll-down": "playerctl -p mpd volume .05-",
    },
    "mpris#short": {
        //"format": "{player_icon} {dynamic}",
        "format": "<i>{title}</i>",
        "max-length": 60,
        "player-icons": {
            "default": "Ō¢Č",
            "mpv": "­¤ÄĄ"
        },
        "status-icons": {
            "playing": "’üŗ",
            "paused": "’üī"
        },
        "on-click": "~/.config/waybar/scripts/media.sh",
        "on-click-right": "playerctl play-pause",
        "on-scroll-up": "playerctl -p mpd volume .05+",
        "on-scroll-down": "playerctl -p mpd volume .05-",
        // "ignored-players": ["firefox"]
    },
    "mpris#icon": {
        //"format": "{player_icon} {dynamic}",
        "format": "{status_icon}",
        "max-length": 60,
        "player-icons": {
            "default": "Ō¢Č",
            "mpv": "­¤ÄĄ"
        },
        "status-icons": {
            "playing": "’üŗ",
            "paused": "’üī"
        },
        "on-click": "~/.config/waybar/scripts/media.sh",
        "on-click-right": "playerctl play-pause",
        "on-scroll-up": "playerctl -p mpd volume .05+",
        "on-scroll-down": "playerctl -p mpd volume .05-",
        // "ignored-players": ["firefox"]
    },
    "image": {
        "path": "/tmp/rmpcd-cover-art",
        "size": 24,
        "interval": 1,
        "on-click":  "hyprctl dispatch togglespecialworkspace music -q",
        "on-click-right": "~/.config/waybar/scripts/viewcover.sh",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },
    "battery": {
    "interval": 60,
    "format": "{capacity}% {icon}",
    "format-icons": {
        "default": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"],
        "charging": ["¾░ó¤", "¾░ó£", "¾░éå", "¾░éć", "¾░éł", "¾░óØ", "¾░éē", "¾░ó×", "¾░éŖ", "¾░éŗ", "¾░éģ"],
    }
}
}
