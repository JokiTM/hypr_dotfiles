{
    "hyprland/workspaces": {
        "show-special": true,
        "special-visible-only": true,
        "format": "{icon}",
        "format-icons": {
            "piracy": "у° і",
            "obs": "пЂЅ",
            "thunderbird": "о¬њ",
            "music": "у°Ћ‡",
            "special": "у°«ў",
        },
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "timezone": "Europe/Berlin",
        //"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        //"format-alt": "п—¬ {:%d/%m/%Y}",
        //"format": "п™Џ {:%H:%M}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon}  {volume}%",
        "format-muted": "п‘¦",
        "format-icons": {
            "default": ["пЂ¦", "пЂ§", "пЂЁ "]
        },
        "on-click": "pavucontrol"
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "hyprlock",
        "format": "пЂЈ",
    },
    "custom/power": {
        "tooltip": false,
        "on-click": "wlogout &",
        "format": "вЏ»"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пЃ®",
            "deactivated": "пЃ°"
        }
    },
    "custom/wireguard": {
        "format": "у°’ѓ",
        "exec": "~/.config/waybar/wireguard.sh",
        "on-click": "rofi -modi 'WireGuard:~/.config/waybar/wireguard-rofi.sh' -show WireGuard",
        "interval": 60,
        "return-type": "json"
    },
    "cpu": {
        "interval": 5,
        "format": "п’ј  {usage}%",
        "max-length": 10,
        "on-click": "hyprctl dispatch togglespecialworkspace sysmon -q",
    },
    "memory": {
        "interval": 5,
        "format": "ої…   {}%",
        "max-length": 10,
        "on-click": "hyprctl dispatch togglespecialworkspace sysmon -q",
    },
    "custom/gpu": {
        "interval": 5,
        "format": "у°ѕІ   {}%",
        "exec": "cat /sys/class/hwmon/hwmon2/device/gpu_busy_percent",
        "max-length": 10,
        "on-click": "hyprctl dispatch togglespecialworkspace sysmon -q",
    },
    "custom/mouse": {
        "format": "у°ЌЅ  {}%",
        "exec": "~/.config/waybar/scripts/mouse.sh",
        "on-click": "notify-send rong",
        "interval": 60,
    },
    "mpris#long": {
        //"format": "{player_icon} {dynamic}",
        "format": "<i>{title} - {artist}</i>  {status_icon}",
        "player-icons": {
            "default": "в–¶",
            "mpv": "рџЋµ"
        },
        "status-icons": {
            "playing": "пЃ‹",
            "paused": "пЃЊ"
        },
        "on-click": "~/.config/waybar/scripts/media.sh",
        "on-scroll-up": "playerctl -p strawberry volume .04+",
        "on-scroll-down": "playerctl -p strawberry volume .04-",
        // "ignored-players": ["firefox"]
    },
    "mpris#short": {
        //"format": "{player_icon} {dynamic}",
        "format": "{status_icon}",
        "player-icons": {
            "default": "в–¶",
            "mpv": "рџЋµ"
        },
        "status-icons": {
            "playing": "пЃ‹",
            "paused": "пЃЊ"
        },
        "on-click": "~/.config/waybar/scripts/media.sh",
        "on-scroll-up": "playerctl -p strawberry volume .04+",
        "on-scroll-down": "playerctl -p strawberry volume .04-",
        // "ignored-players": ["firefox"]
    },
    "image": {
        "exec": "~/.config/waybar/scripts/cover.sh",
        //"path": "/tmp/strawberry-cover-eidtfg.jpg",
        "size": 32,
        "interval": 5,
        "on-click":  "hyprctl dispatch togglespecialworkspace music -q",
        "on-click-right": "~/.config/waybar/scripts/viewcover.sh",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    }
}
