{
    "cpu": {
        "interval": 5,
        "format": "  {usage}%",
        "max-length": 10,
        "on-click": "hyprctl dispatch togglespecialworkspace sysmon -q"
    },
    "custom/cpu-temp": {
        "exec": "~/.config/waybar/scripts/cpu.sh",
        "interval": "5"
    },
    "memory": {
        "interval": 5,
        "format": "   {}%",
        "max-length": 10,
        "on-click": "hyprctl dispatch togglespecialworkspace sysmon -q"
    },
    "custom/gpu": {
        "interval": 5,
        "format": "󰾲   {}%",
        "exec": "~/.config/waybar/scripts/test.sh",
        "max-length": 10,
        "on-click": "hyprctl dispatch togglespecialworkspace sysmon -q"
    },
    "custom/vram": {
        "interval": 5,
        "format": "{} GiB Used",
        "exec": "~/.config/waybar/scripts/gpu.sh vram",
        "on-click": "hyprctl dispatch togglespecialworkspace sysmon -q"
    },
    "custom/gpu-temp": {
        "exec": "~/.config/waybar/scripts/gpu.sh temp",
        "interval": 5,
        "on-click": "hyprctl dispatch togglespecialworkspace sysmon -q"
    },
    "custom/mouse": {
        "format": "󰍽  {}%",
        "exec": "~/.config/waybar/scripts/mouse.sh",
        "on-click": "notify-send rong",
        "interval": 60
    },
    "group/cpu": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500,
            "transition-left-to-right": true
        },
        "modules": [
            "cpu",
            "custom/cpu-temp"
        ]
    },
    "group/gpu": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500,
            "transition-left-to-right": true
        },
        "modules": [
            "custom/gpu",
            "custom/gpu-temp",
            "custom/vram"
        ]
    }
}
